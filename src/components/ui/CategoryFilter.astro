---
interface Props {
  categories: string[];
  selectedCategory?: string | null;
  baseUrl?: string;
}

const { categories, selectedCategory = null, baseUrl = "/products" } = Astro.props;

// Format category name for display
function formatCategoryName(category: string): string {
  return category
    .split("-")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
}

const isAllSelected = !selectedCategory || selectedCategory === "all";
---

<div class="mb-8 flex flex-wrap gap-4 justify-center border-b border-neutral-300 pb-4 dark:border-neutral-700">
  <a
    href={baseUrl}
    class={`px-4 py-2 text-sm font-medium transition-colors ${
      isAllSelected
        ? "border-b-2 border-neutral-800 text-neutral-800 dark:border-neutral-200 dark:text-neutral-200"
        : "text-neutral-600 hover:text-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-200"
    }`}
  >
    All
  </a>
  {categories.map((category) => (
    <a
      href={`${baseUrl}/category/${category}`}
      class={`px-4 py-2 text-sm font-medium transition-colors ${
        selectedCategory === category
          ? "border-b-2 border-neutral-800 text-neutral-800 dark:border-neutral-200 dark:text-neutral-200"
          : "text-neutral-600 hover:text-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-200"
      }`}
    >
      {formatCategoryName(category)}
    </a>
  ))}
</div>
