---
interface Props {
  category: string;
  categoryImage: string;
  categoryUrl: string;
}

const { category, categoryImage, categoryUrl } = Astro.props;

// Format category name for display
function formatCategoryName(category: string): string {
  return category
    .split("-")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
}
---

<div class="bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition-shadow dark:bg-neutral-900 w-full sm:w-[calc(50%-12px)] md:w-[calc(33.333%-16px)] lg:w-[calc(25%-18px)] flex flex-col">
  <div class="aspect-square overflow-hidden bg-neutral-100 dark:bg-neutral-800 flex-shrink-0">
    <img
      src={categoryImage}
      alt={formatCategoryName(category)}
      class="w-full h-full object-cover"
      loading="lazy"
    />
  </div>
  <div class="p-4 flex-1 flex flex-col">
    <h3 class="text-lg font-semibold text-neutral-800 mb-4 dark:text-neutral-200">
      {formatCategoryName(category)}
    </h3>
    <a
      href={categoryUrl}
      class="mt-auto px-4 py-2 text-sm font-medium text-center rounded border border-neutral-800 text-neutral-800 hover:bg-neutral-100 dark:border-neutral-200 dark:text-neutral-200 dark:hover:bg-neutral-800 transition-colors"
    >
      ნახეთ მეტი
    </a>
  </div>
</div>
