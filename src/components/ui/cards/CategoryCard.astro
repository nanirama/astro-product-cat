---
interface Props {
  category: string;
  categoryImage: string;
  categoryUrl: string;
}

const { category, categoryImage, categoryUrl } = Astro.props;

// Format category name for display
function formatCategoryName(category: string): string {
  return category
    .split("-")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
}
---

<div
  class="flex w-full flex-col overflow-hidden rounded-lg bg-white shadow-sm transition-shadow hover:shadow-md sm:w-[calc(50%-12px)] md:w-[calc(33.333%-16px)] lg:w-[calc(25%-18px)] dark:bg-neutral-900"
>
  <a href={categoryUrl}>
    <div
      class="aspect-square flex-shrink-0 overflow-hidden bg-neutral-100 dark:bg-neutral-800"
    >
      <img
        src={categoryImage}
        alt={formatCategoryName(category)}
        class="h-full w-full object-cover"
        loading="lazy"
      />
    </div>
    <div class="flex flex-1 flex-col p-4">
      <h3
        class="mb-4 text-lg font-semibold text-neutral-800 dark:text-neutral-200"
      >
        {formatCategoryName(category)}
      </h3>
      <div
        class="mt-auto rounded border border-neutral-800 px-4 py-2 text-center text-sm font-medium text-neutral-800 transition-colors hover:bg-neutral-100 dark:border-neutral-200 dark:text-neutral-200 dark:hover:bg-neutral-800"
      >
        ნახეთ მეტი
      </div>
    </div>
  </a>
</div>
