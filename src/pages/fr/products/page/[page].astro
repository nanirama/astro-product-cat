---
import MainLayout from "@/layouts/MainLayout.astro";
import ProductCard from "@components/ui/cards/ProductCard.astro";
import Pagination from "@components/ui/Pagination.astro";
import CategoryFilter from "@components/ui/CategoryFilter.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";

export async function getStaticPaths() {
  const allProducts: CollectionEntry<"products">[] = await getCollection("products");
  
  const productsPerPage = 8;
  const totalPages = Math.max(1, Math.ceil(allProducts.length / productsPerPage));
  
  // Generate paths for pages 2 and onwards (page 1 is handled by index.astro)
  const paths: Array<{ params: { page: string } }> = [];
  for (let page = 2; page <= totalPages; page++) {
    paths.push({
      params: { page: page.toString() },
    });
  }
  
  return paths;
}

const { page } = Astro.params;
const currentPage = parseInt(page || "1", 10);

// Get all products
const allProducts: CollectionEntry<"products">[] = await getCollection("products");

// Extract all unique categories from products
const allCategories = Array.from(
  new Set(
    allProducts.flatMap((product) => product.data.category || [])
  )
).sort();

// Pagination: 4 products per page
const productsPerPage = 8;
const totalPages = Math.max(1, Math.ceil(allProducts.length / productsPerPage));
const startIndex = (currentPage - 1) * productsPerPage;
const endIndex = startIndex + productsPerPage;
const paginatedProducts = allProducts.slice(startIndex, endIndex);

const pageTitle = currentPage > 1 ? `Products - Page ${currentPage} | ${SITE.title}` : `Products | ${SITE.title}`;
const metaDescription = "Browse our catalog of products";
---

<MainLayout title={pageTitle} customDescription={metaDescription}>
  <div class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
    <!-- Page Title -->
    <h1 class="text-4xl font-bold tracking-tight text-balance text-center text-neutral-800 mb-8 md:text-5xl dark:text-neutral-200">
      Our Catalogs
    </h1>

    <!-- Category Filter -->
    <CategoryFilter categories={allCategories} selectedCategory={null} baseUrl="/products" />

    <!-- Products Grid -->
    {paginatedProducts.length > 0 ? (
      <div class="flex flex-wrap justify-center gap-6 mb-12">
        {paginatedProducts.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    ) : (
      <div class="text-center py-12 mb-12">
        <p class="text-lg text-neutral-600 dark:text-neutral-400">
          No products found.
        </p>
      </div>
    )}

    <!-- Pagination -->
    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      baseUrl="/products"
      pageUrlPattern="/products/page/{page}"
    />
  </div>
</MainLayout>
