---
import MainLayout from "@/layouts/MainLayout.astro";
import ProductImageGallery from "@components/ui/ProductImageGallery.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";
import SocialShare from "@components/products/SocialShare";

export async function getStaticPaths() {
  const allProducts: CollectionEntry<"products">[] = await getCollection("products");
  
  return allProducts.map((product) => ({
    params: { slug: product.data.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);

// Format price for display
function formatPrice(price: number | null, currency: string | null): string {
  if (price === null) return "";
  if (currency === null) return `$${price.toLocaleString()}`;
  return `${price.toLocaleString()} ${currency}`;
}

// Get all images (main + additional)
const allImages = product.data.images 
  ? [product.data.main_image, ...product.data.images]
  : [product.data.main_image];

const selectedImage = Astro.url.searchParams.get("image") || "0";
const currentImageIndex = parseInt(selectedImage) || 0;
const mainImage = allImages[currentImageIndex] || product.data.main_image;

// Get selected color from URL or default to first color
const selectedColor = Astro.url.searchParams.get("color") || (product.data.color?.[0] || null);

// SEO and Meta
const pageTitle = `${product.data.title} | ${SITE.title}`;
const metaDescription = product.data.short_description || ``;
const canonicalUrl = new URL(`/products/${product.data.slug}`, Astro.site || Astro.url.origin).href;

// Ensure image URL is absolute - handle both relative paths starting with / and absolute URLs
const imagePath = product.data.main_image.startsWith('http') 
  ? product.data.main_image 
  : product.data.main_image.startsWith('/')
    ? product.data.main_image
    : `/${product.data.main_image}`;
const productImageUrl = new URL(imagePath, Astro.site || Astro.url.origin).href;

// Detect image type from file extension
const getImageType = (imagePath: string): string => {
  const ext = imagePath.toLowerCase().split('.').pop();
  if (ext === 'png') return 'image/png';
  if (ext === 'jpg' || ext === 'jpeg') return 'image/jpeg';
  if (ext === 'webp') return 'image/webp';
  if (ext === 'avif') return 'image/avif';
  return 'image/jpeg'; // default
};
const imageType = getImageType(product.data.main_image);

// Generate structured data for Product schema
const productStructuredData = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.data.title,
  "description": product.data.short_description,
  "image": allImages.map(img => new URL(img, Astro.site || Astro.url.origin).href),
  "brand": {
    "@type": "Brand",
    "name": product.data.title.split(',')[0] || SITE.title
  },
  "offers": product.data.price !== null ? {
    "@type": "Offer",
    "price": product.data.price,
    "priceCurrency": product.data.currency || "USD",
    "availability": "https://schema.org/InStock",
    "url": canonicalUrl
  } : undefined,
  "category": product.data.category?.map(cat => 
    cat.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')
  ).join(', '),
  "sku": product.data.slug,
  "mpn": product.data.slug,
  ...(product.data.dimensions && { "size": product.data.dimensions }),
  ...(product.data.weight && { "weight": product.data.weight }),
  ...(product.data.color && product.data.color.length > 0 && { 
    "color": product.data.color.map(c => c.charAt(0).toUpperCase() + c.slice(1)).join(', ')
  })
};

// Breadcrumb structured data
const breadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": new URL("/", Astro.site || Astro.url.origin).href
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Catalog",
      "item": new URL("/products", Astro.site || Astro.url.origin).href
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": product.data.title,
      "item": canonicalUrl
    }
  ]
};
console.log('metaDescription',metaDescription)
console.log('pageTitle',pageTitle)
---

<MainLayout 
  title={pageTitle} 
  customDescription={metaDescription}
  customOgTitle={pageTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@graph": [productStructuredData, breadcrumbStructuredData]
  }}
  ogImage={productImageUrl}
  ogUrl={canonicalUrl}
>
  {/* Structured Data */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productStructuredData)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbStructuredData)} />
  

  <div class="mx-auto max-w-[85rem] px-4 py-6 sm:px-6 sm:py-8 lg:px-8 lg:py-12 2xl:max-w-full">
    <!-- Breadcrumb Navigation -->
    <nav class="mb-6 sm:mb-8" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-2 text-sm text-neutral-600 dark:text-neutral-400" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/" class="hover:text-neutral-800 dark:hover:text-neutral-200 focus:outline-none focus:ring-2 focus:ring-neutral-800 focus:ring-offset-2 dark:focus:ring-neutral-200 rounded" itemprop="item">
            <span itemprop="name">Home</span>
          </a>
          <meta itemprop="position" content="1" />
        </li>
        <li class="before:content-['>'] before:mx-2" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/products" class="hover:text-neutral-800 dark:hover:text-neutral-200 focus:outline-none focus:ring-2 focus:ring-neutral-800 focus:ring-offset-2 dark:focus:ring-neutral-200 rounded" itemprop="item">
            <span itemprop="name">Catalog</span>
          </a>
          <meta itemprop="position" content="2" />
        </li>
        <li class="before:content-['>'] before:mx-2" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="text-neutral-800 dark:text-neutral-200" itemprop="name">{product.data.title}</span>
          <meta itemprop="position" content="3" />
        </li>
      </ol>
    </nav>

    <!-- Product Details Section -->
    <article class="grid grid-cols-1 gap-6 sm:gap-8 lg:grid-cols-[2fr_2fr_1fr] lg:gap-8" itemscope itemtype="https://schema.org/Product">
      <!-- Column 1: Product Images -->
      <div class="order-1">
        <ProductImageGallery
          mainImage={mainImage}
          allImages={allImages}
          currentImageIndex={currentImageIndex}
          productTitle={product.data.title}
          selectedColor={selectedColor}
        />
      </div>

      <!-- Column 2: Product Information -->
      <div class="flex flex-col order-2">
        <!-- Product Title -->
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-neutral-900 mb-3 sm:mb-4 dark:text-neutral-100" itemprop="name">
          {product.data.title.split(',')[0] || product.data.title}
        </h1>

        <!-- Price -->
        {product.data.price !== null && (
          <div class="mb-4 sm:mb-6" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
            <meta itemprop="price" content={product.data.price.toString()} />
            <meta itemprop="priceCurrency" content={product.data.currency || "USD"} />
            <p class="text-2xl sm:text-3xl font-bold text-neutral-900 dark:text-neutral-100" aria-label={`Price: ${formatPrice(product.data.price, product.data.currency)}`}>
              ფასი: {formatPrice(product.data.price, product.data.currency)}
            </p>
          </div>
        )}

        <!-- Color Selection -->
        {product.data.color && product.data.color.length > 0 && (
          <div class="mb-4 sm:mb-6">
            <h2 class="text-sm font-medium text-neutral-700 mb-2 sm:mb-3 dark:text-neutral-300">Color</h2>
            <div class="flex flex-wrap gap-2 sm:gap-3" role="group" aria-label="Color selection">
              {product.data.color.map((color) => (
                <button
                  type="button"
                  aria-pressed={selectedColor === color}
                  aria-label={`Select color ${color}`}
                  class={`px-4 py-2 sm:px-6 sm:py-2 text-sm sm:text-base rounded border-2 transition-all focus:outline-none focus:ring-2 focus:ring-neutral-800 focus:ring-offset-2 dark:focus:ring-neutral-200 min-h-[44px] ${
                    selectedColor === color
                      ? "bg-neutral-800 text-white border-neutral-800 dark:bg-neutral-200 dark:text-neutral-800 dark:border-neutral-200"
                      : "bg-neutral-100 text-neutral-600 border-neutral-300 hover:border-neutral-400 dark:bg-neutral-800 dark:text-neutral-400 dark:border-neutral-700"
                  }`}
                  onclick={`window.location.href='?image=${currentImageIndex}&color=${color}'`}
                >
                  {color.charAt(0).toUpperCase() + color.slice(1)}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- About Product -->
        <div class="mb-2">
          <h2 class="text-lg sm:text-xl font-semibold text-neutral-800 mb-3 dark:text-neutral-200">
            დეტალები
          </h2>
          <div class="mb-4 text-neutral-600 leading-relaxed dark:text-neutral-400 prose prose-neutral dark:prose-invert max-w-none prose-sm sm:prose-base" itemprop="description">
            <Content />
          </div>
          <div class="mt-auto w-full block my-2">
            <a
              href={``}
              class="inline-block w-full sm:w-auto px-6 py-3 sm:px-8 sm:py-4 text-base sm:text-lg font-semibold text-white bg-neutral-800 hover:bg-neutral-700 dark:bg-neutral-200 dark:text-neutral-800 dark:hover:bg-neutral-300 rounded-lg transition-colors duration-200 text-center focus:outline-none focus:ring-2 focus:ring-neutral-800 focus:ring-offset-2 dark:focus:ring-neutral-200 min-h-[44px] flex items-center justify-center"
              aria-label={`Request a quote for ${product.data.title}`}
            >
              ტელ: 551553203
            </a>
          </div>
        </div>
        <div class="inline-flex  py-4 mb-8">
        <SocialShare
          client:load
          url={canonicalUrl}
          title={product.data.title}
        />
      </div>

        <!-- Request a Quote Button -->
        
      </div>

      <!-- Column 3: Product Specifications -->
      <aside class="order-3 lg:top-6 lg:self-start" aria-label="Product specifications">
        <div class="bg-white dark:bg-neutral-900 rounded-lg p-4 sm:p-6 border border-neutral-200 dark:border-neutral-800 shadow-sm">
          <h2 class="text-lg sm:text-xl font-bold text-neutral-800 mb-4 sm:mb-6 text-center dark:text-neutral-200">
            მახასიათებლები
          </h2>

          <dl class="space-y-3 sm:space-y-4">


            <!-- Dimension -->
            {product.data.dimensions && (
              <div class="flex justify-between items-start pb-3 sm:pb-4 border-b border-neutral-200 dark:border-neutral-700">
                <dt class="text-sm font-medium text-neutral-700 dark:text-neutral-300 w-[40%]">აწევის სიმაღლე</dt>
                <dd class="text-sm text-neutral-600 dark:text-neutral-400 w-[60%] text-right" itemprop="size">{product.data.dimensions}</dd>
              </div>
            )}

            <!-- Weight -->
            {product.data.weight && (
              <div class="flex justify-between items-start pb-3 sm:pb-4 border-b border-neutral-200 dark:border-neutral-700">
                <dt class="text-sm font-medium text-neutral-700 dark:text-neutral-300 w-[40%]">ტვირთამწეობა</dt>
                <dd class="text-sm text-neutral-600 dark:text-neutral-400 w-[60%] text-right" itemprop="weight">{product.data.weight}</dd>
              </div>
            )}

            <!-- Color Display -->
            {selectedColor && (
              <div class="flex justify-between items-start pb-3 sm:pb-4 border-b border-neutral-200 dark:border-neutral-700">
                <dt class="text-sm font-medium text-neutral-700 dark:text-neutral-300 w-[40%]">Color</dt>
                <dd class="text-sm text-neutral-600 dark:text-neutral-400 capitalize w-[60%] text-right" itemprop="color">{selectedColor}</dd>
              </div>
            )}

            <!-- Delivery Cost -->
            {product.data.delivery_cost !== null && (
              <div class="flex justify-between items-start pb-3 sm:pb-4 border-b border-neutral-200 dark:border-neutral-700">
                <dt class="text-sm font-medium text-neutral-700 dark:text-neutral-300 w-[40%]">Delivery Cost</dt>
                <dd class="text-sm text-neutral-600 dark:text-neutral-400 w-[60%] text-right">
                  {formatPrice(product.data.delivery_cost, product.data.currency)}
                </dd>
              </div>
            )}

            <!-- Category -->
            {product.data.category && product.data.category.length > 0 && (
              <div class="flex justify-between items-start pb-3 sm:pb-4 border-b border-neutral-200 dark:border-neutral-700">
                <dt class="text-sm font-medium text-neutral-700 dark:text-neutral-300">კატეგორია</dt>
                <dd class="text-sm text-neutral-600 dark:text-neutral-400 w-[60%] text-right">
                  {product.data.category.map(cat => cat.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')).join(', ')}
                </dd>
              </div>
            )}
          </dl>
        </div>
      </aside>
    </article>
  </div>
</MainLayout>

